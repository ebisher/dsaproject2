int main() {
    StudentSystem sys;

    // Seed with sample data
    sys.addStudent({"Alice Chen",    3.92f, 10001, 2025, "Computer Science", "Robotics, Math Club"});
    sys.addStudent({"Marcus Webb",   3.45f, 10002, 2026, "Biology",          "Soccer, NHS"});
    sys.addStudent({"Priya Patel",   2.88f, 10003, 2027, "History",          "Drama Club"});
    sys.addStudent({"Jordan Lee",    3.70f, 10004, 2025, "Mathematics",      "Debate, Chess Club"});
    sys.addStudent({"Sofia Reyes",   2.30f, 10005, 2028, "Fine Arts",        "Art Society, Yearbook"});
    sys.addStudent({"Ethan Brooks",  3.55f, 10006, 2026, "Physics",          "Science Olympiad"});

    int choice = 0;
    while (true) {
        printHeader("Student Information System");
        std::cout << "  Total students: " << sys.size()
                  << "  |  Avg GPA: "
                  << std::fixed << std::setprecision(2) << sys.averageGPA() << "\n\n";
        std::cout << "  [1] List all students\n"
                  << "  [2] Add a student\n"
                  << "  [3] Update a student\n"
                  << "  [4] Delete a student\n"
                  << "  [5] Search by ID  — Jump Search\n"
                  << "  [6] Search by ID  — Interpolation Search\n"
                  << "  [7] View honors roll  (GPA >= 3.5)\n"
                  << "  [8] Filter by class year\n"
                  << "  [0] Exit\n";

        choice = readInt("\n  Choose an option: ");

        switch (choice) {
        case 1:
            printHeader("All Students");
            sys.listAll();
            break;

        case 2:
            printHeader("Add Student");
            sys.addStudent(inputStudent());
            break;

        case 3: {
            int id = readInt("  Enter ID of student to update: ");
            std::cout << "  Enter new details:\n";
            Student updated = inputStudent();
            sys.updateStudent(id, updated);
            break;
        }

        case 4: {
            int id = readInt("  Enter ID of student to delete: ");
            sys.deleteStudent(id);
            break;
        }

        case 5: {
            int id = readInt("  Enter ID to search: ");
            sys.searchByIDJump(id);
            break;
        }

        case 6: {
            int id = readInt("  Enter ID to search: ");
            sys.searchByIDInterpolation(id);
            break;
        }

        case 7:
            sys.showHonorsRoll();
            break;

        case 8: {
            int yr = readInt("  Enter class year: ");
            sys.showClassYear(yr);
            break;
        }

        case 0:
            std::cout << "\n  Goodbye!\n\n";
            return 0;

        default:
            std::cout << "  [Error] Invalid option. Try again.\n";
        }

        std::cout << "\n  Press Enter to continue...";
        std::cin.ignore(std::numeric_limits<std::streamsize>::max(), '\n');
    }
}
